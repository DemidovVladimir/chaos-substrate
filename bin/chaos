#!/usr/bin/env bash
set -euo pipefail

# Single-file `chaos` entrypoint. `install-agent` symlinks this onto PATH
# (~/.local/bin/chaos -> bin/chaos), so resolve the symlink chain first to
# find the real checkout root.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" == /* ]]; then
    SOURCE="$TARGET"
  else
    SOURCE="$DIR/$TARGET"
  fi
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
CONFIG="${CHAOS_CONFIG:-$ROOT/chaos-substrate.toml}"
BIN="${CHAOS_BIN:-$ROOT/target/release/chaos}"

usage() {
  cat <<'USAGE'
Wrapper-managed commands (setup/orchestration; this script):
  chaos bootstrap
  chaos install-agent [bin-dir]
  chaos doctor
  chaos ollama-setup
  chaos onboard <repo-path>
  chaos project-instructions <repo-path>
  chaos init <repo-path>
  chaos update <repo-path>
  chaos context <repo-path> <task>
  chaos explain <repo-path> <feature-or-task>
  chaos claude-code-add [local|project|user] [claude-project-dir]
  chaos mcp

Every other command passes straight through to the chaos binary with this
repo's config — chaos analyze/add/stats/query/features/components/project/
change-plan/clean/… all work. Run `chaos help` for the full guide.

Environment:
  CHAOS_CONFIG     Path to chaos-substrate.toml. Defaults to this repo's config.
  CHAOS_BIN        Path to chaos binary. Defaults to target/release/chaos.
  CHAOS_AGENT_BIN_DIR  Directory for install-agent. Defaults to ~/.local/bin.
  CHAOS_FORCE_BUILD  Set to 1 to rebuild the release binary even if it exists.
  DATABASE_URL     Database URL passed to Claude Code MCP. Defaults to local docker compose URL.
  CHAOS_NO_DOCKER  Set to 1 to skip docker compose up -d.
USAGE
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

ensure_binary() {
  if [ -x "$BIN" ] && [ "${CHAOS_FORCE_BUILD:-0}" != "1" ]; then
    changed="$(
      find "$ROOT/src" "$ROOT/migrations" "$ROOT/Cargo.toml" "$ROOT/Cargo.lock" \
        -newer "$BIN" -print -quit 2>/dev/null || true
    )"
    if [ "$changed" = "" ]; then
      return
    fi
  fi
  (cd "$ROOT" && cargo build --release >&2)
}

config_value() {
  section="$1"
  key="$2"
  awk -v section="$section" -v key="$key" '
    $0 ~ "^[[:space:]]*\\[" section "\\][[:space:]]*$" { in_section = 1; next }
    $0 ~ "^[[:space:]]*\\[" { in_section = 0 }
    in_section && $0 ~ "^[[:space:]]*" key "[[:space:]]*=" {
      sub(/#.*/, "", $0)
      sub(/^[^=]*=[[:space:]]*/, "", $0)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
      gsub(/^"|"$/, "", $0)
      print
      exit
    }
  ' "$CONFIG" 2>/dev/null || true
}

embedding_provider() {
  config_value embedding provider
}

ensure_services() {
  if [ "${CHAOS_NO_DOCKER:-0}" = "1" ]; then
    return
  fi
  (cd "$ROOT" && docker compose up -d)
}

wait_for_ollama() {
  attempts="${1:-30}"
  while [ "$attempts" -gt 0 ]; do
    if curl -fsS http://localhost:11434/api/tags >/dev/null 2>&1; then
      return 0
    fi
    attempts=$((attempts - 1))
    sleep 1
  done
  return 1
}

start_ollama() {
  if curl -fsS http://localhost:11434/api/tags >/dev/null 2>&1; then
    return 0
  fi

  os="$(uname -s 2>/dev/null || printf unknown)"
  case "$os" in
    Darwin)
      if command -v open >/dev/null 2>&1; then
        open -a Ollama >/dev/null 2>&1 || true
      fi
      if ! curl -fsS http://localhost:11434/api/tags >/dev/null 2>&1; then
        nohup ollama serve >/tmp/chaos-substrate-ollama.log 2>&1 &
      fi
      ;;
    Linux)
      if command -v systemctl >/dev/null 2>&1; then
        systemctl --user start ollama >/dev/null 2>&1 || true
        systemctl start ollama >/dev/null 2>&1 || true
      fi
      if ! curl -fsS http://localhost:11434/api/tags >/dev/null 2>&1; then
        nohup ollama serve >/tmp/chaos-substrate-ollama.log 2>&1 &
      fi
      ;;
  esac

  wait_for_ollama 30
}

install_agent() {
  bin_dir="${1:-${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}}"
  mkdir -p "$bin_dir"
  ln -sf "$ROOT/bin/chaos" "$bin_dir/chaos"
  cat <<INSTALL
Installed chaos:
  $bin_dir/chaos -> $ROOT/bin/chaos

If this directory is not on PATH, add:
  export PATH="$bin_dir:\$PATH"
INSTALL
}

append_managed_section() {
  file="$1"
  title="$2"
  if [ -f "$file" ] && grep -q '<!-- chaos-substrate:start -->' "$file"; then
    printf 'Chaos Substrate section already exists in %s\n' "$file"
    return
  fi
  if [ -f "$file" ] && [ -s "$file" ]; then
    printf '\n' >> "$file"
  fi
  cat >> "$file" <<EOF
<!-- chaos-substrate:start -->
## Chaos Substrate

Use Chaos Substrate before non-trivial architecture, security, feature, or refactor work.

- Prefer \`chaos update "\$PWD"\` after code changes or before deep investigation.
- Use \`chaos context "\$PWD" "<task>"\` before implementation work.
- Use \`chaos explain "\$PWD" "<feature>"\` to generate a focused static feature page.
- If MCP tools are available, use \`chaos_analyze\` to index and \`chaos_query\` for focused questions.
- Treat source code as higher priority than docs if they disagree.
- Read generated feature manifests in \`docs/features_memory/*.html\`; do not scan the whole docs tree.
- Feature-map story steps must use explicit \`node_ids\` and optional \`edge_ids\`, not graph expansion.

This section is intentionally portable. It assumes \`chaos\` is on PATH.
<!-- chaos-substrate:end -->
EOF
  printf 'Wrote Chaos Substrate section to %s (%s)\n' "$file" "$title"
}

write_project_instructions() {
  repo="${1:-}"
  need_repo "$repo"
  if [ ! -d "$repo" ]; then
    printf 'Project directory does not exist: %s\n' "$repo" >&2
    exit 2
  fi
  repo="$(cd "$repo" && pwd)"
  append_managed_section "$repo/AGENTS.md" "generic agents"
  append_managed_section "$repo/CLAUDE.md" "Claude Code / Cowork"
}

ollama_setup() {
  if ! command -v ollama >/dev/null 2>&1; then
    cat <<'OLLAMA'
Ollama is not installed or is not on PATH.

Install Ollama:
  macOS / Windows: download from https://ollama.com/download
  Linux:           curl -fsSL https://ollama.com/install.sh | sh

After installing, start Ollama and rerun:
  chaos ollama-setup
OLLAMA
    return 1
  fi

  if ! start_ollama; then
    cat <<'OLLAMA'
Ollama CLI is installed, but the local server is not responding on http://localhost:11434.

The wrapper tried to start Ollama automatically.

If it is still unavailable, start it manually and rerun:
  macOS / Windows: open the Ollama desktop app
  Linux:           ollama serve
OLLAMA
    return 1
  fi

  printf 'Ollama server is running on http://localhost:11434\n'
  ollama pull nomic-embed-text
  cat <<'OLLAMA'
Ollama embedding model is ready.

Use the local Ollama config:
  CHAOS_CONFIG=chaos-substrate.local.toml chaos doctor
  CHAOS_CONFIG=chaos-substrate.local.toml chaos init /absolute/path/to/project
OLLAMA
}

ensure_embedder_ready() {
  provider="$(embedding_provider)"
  case "$provider" in
    ollama)
      ollama_setup
      ;;
    open_ai|openai)
      if [ "${OPENAI_API_KEY:-}" = "" ]; then
        cat <<'OPENAI' >&2
OpenAI embeddings are configured, but OPENAI_API_KEY is not set.

Set OPENAI_API_KEY or switch CHAOS_CONFIG to an Ollama config.
OPENAI
        return 1
      fi
      ;;
  esac
}

chaos() {
  "$BIN" --config "$CONFIG" "$@"
}

need_repo() {
  if [ "${1:-}" = "" ]; then
    usage
    exit 2
  fi
}

cmd="${1:-}"
shift || true

case "$cmd" in
  bootstrap)
    install_agent "${1:-${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}}"
    ensure_binary
    ensure_embedder_ready
    ensure_services
    chaos migrate
    chaos doctor
    ;;
  install-agent)
    install_agent "${1:-${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}}"
    ;;
  doctor)
    ensure_binary
    ensure_embedder_ready
    ensure_services
    chaos migrate
    chaos doctor
    ;;
  ollama-setup)
    ollama_setup
    ;;
  project-instructions)
    repo="${1:-}"
    write_project_instructions "$repo"
    ;;
  onboard)
    repo="${1:-}"
    need_repo "$repo"
    install_agent "${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}"
    write_project_instructions "$repo"
    ensure_binary
    ensure_embedder_ready
    ensure_services
    chaos migrate
    chaos doctor
    chaos analyze "$repo"
    chaos refresh "$repo"
    ;;
  init)
    repo="${1:-}"
    need_repo "$repo"
    ensure_binary
    ensure_embedder_ready
    ensure_services
    chaos migrate
    chaos doctor
    chaos analyze "$repo"
    chaos refresh "$repo"
    ;;
  update)
    repo="${1:-}"
    need_repo "$repo"
    ensure_binary
    ensure_embedder_ready
    ensure_services
    chaos migrate
    chaos analyze "$repo"
    chaos refresh "$repo"
    ;;
  context)
    repo="${1:-}"
    task="${2:-}"
    need_repo "$repo"
    if [ "$task" = "" ]; then
      usage
      exit 2
    fi
    ensure_binary
    chaos feature-context "$repo" "$task"
    ;;
  explain)
    repo="${1:-}"
    task="${2:-}"
    need_repo "$repo"
    if [ "$task" = "" ]; then
      usage
      exit 2
    fi
    ensure_binary
    slug="$(slugify "$task")"
    if [ "$slug" = "" ]; then
      slug="feature-context"
    fi
    output="$repo/docs/features_memory/$slug-explanation.html"
    chaos feature-context "$repo" "$task" --output-html "$output"
    printf '\nWrote %s\n' "$output"
    ;;
  claude-code-add)
    scope="${1:-local}"
    project_dir="${2:-$PWD}"
    case "$scope" in
      local|project|user) ;;
      *)
        usage
        exit 2
        ;;
    esac
    if [ ! -d "$project_dir" ]; then
      printf 'Claude project directory does not exist: %s\n' "$project_dir" >&2
      exit 2
    fi
    if ! command -v claude >/dev/null 2>&1; then
      cat <<'CLAUDE'
Claude Code CLI is not installed or is not on PATH.

Install Claude Code first, then rerun:
  chaos claude-code-add local
CLAUDE
      exit 1
    fi
    ensure_binary
    (
      cd "$project_dir"
      claude mcp add chaos-substrate \
        --scope "$scope" \
        --env "DATABASE_URL=${DATABASE_URL:-postgres://chaos:chaos@localhost:54329/chaos_substrate}" \
        -- "$BIN" --config "$CONFIG" mcp
    )
    ;;
  mcp)
    ensure_binary
    exec "$BIN" --config "$CONFIG" mcp
    ;;
  ""|-h|--help)
    usage
    ;;
  help)
    # The binary's agent guide first (commands + workflows), then the
    # wrapper-only extras this script adds on top.
    ensure_binary
    "$BIN" help "$@"
    printf '\n'
    usage
    ;;
  -*)
    # Caller passed their own flags (e.g. --config) — forward verbatim,
    # without injecting the wrapper's config a second time.
    ensure_binary
    exec "$BIN" "$cmd" "$@"
    ;;
  *)
    # Pass-through: every real chaos subcommand (analyze, add, stats, query,
    # features, components, project, change-plan, clean, …) runs against this
    # repo's config. Unknown names get clap's own error + suggestions, so this
    # wrapper never needs a hardcoded command list again.
    ensure_binary
    exec "$BIN" --config "$CONFIG" "$cmd" "$@"
    ;;
esac
