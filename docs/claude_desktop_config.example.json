{
  "mcpServers": {
    "chaos-substrate": {
      "command": "/absolute/path/to/chaos-substrate/target/release/chaos",
      "args": [
        "--config",
        "/absolute/path/to/chaos-substrate/chaos-substrate.toml",
        "mcp"
      ],
      "env": {
        "DATABASE_URL": "postgres://chaos:chaos@localhost:54329/chaos_substrate"
      }
    }
  }
}
