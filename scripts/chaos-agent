#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG="${CHAOS_CONFIG:-$ROOT/chaos-substrate.toml}"
BIN="${CHAOS_BIN:-$ROOT/target/release/chaos}"

usage() {
  cat <<'USAGE'
Usage:
  scripts/chaos-agent bootstrap
  scripts/chaos-agent install-agent [bin-dir]
  scripts/chaos-agent doctor
  scripts/chaos-agent ollama-setup
  scripts/chaos-agent onboard <repo-path>
  scripts/chaos-agent project-instructions <repo-path>
  scripts/chaos-agent init <repo-path>
  scripts/chaos-agent update <repo-path>
  scripts/chaos-agent context <repo-path> <task>
  scripts/chaos-agent explain <repo-path> <feature-or-task>
  scripts/chaos-agent claude-code-add [local|project|user] [claude-project-dir]
  scripts/chaos-agent mcp

Environment:
  CHAOS_CONFIG     Path to chaos-substrate.toml. Defaults to this repo's config.
  CHAOS_BIN        Path to chaos binary. Defaults to target/release/chaos.
  CHAOS_AGENT_BIN_DIR  Directory for install-agent. Defaults to ~/.local/bin.
  DATABASE_URL     Database URL passed to Claude Code MCP. Defaults to local docker compose URL.
  CHAOS_NO_DOCKER  Set to 1 to skip docker compose up -d.
USAGE
}

slugify() {
  printf '%s' "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

ensure_binary() {
  if [ ! -x "$BIN" ]; then
    (cd "$ROOT" && cargo build --release)
  fi
}

ensure_services() {
  if [ "${CHAOS_NO_DOCKER:-0}" = "1" ]; then
    return
  fi
  (cd "$ROOT" && docker compose up -d)
}

install_agent() {
  bin_dir="${1:-${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}}"
  mkdir -p "$bin_dir"
  ln -sf "$ROOT/scripts/chaos-agent" "$bin_dir/chaos-agent"
  cat <<INSTALL
Installed chaos-agent:
  $bin_dir/chaos-agent -> $ROOT/scripts/chaos-agent

If this directory is not on PATH, add:
  export PATH="$bin_dir:\$PATH"
INSTALL
}

append_managed_section() {
  file="$1"
  title="$2"
  if [ -f "$file" ] && grep -q '<!-- chaos-substrate:start -->' "$file"; then
    printf 'Chaos Substrate section already exists in %s\n' "$file"
    return
  fi
  if [ -f "$file" ] && [ -s "$file" ]; then
    printf '\n' >> "$file"
  fi
  cat >> "$file" <<EOF
<!-- chaos-substrate:start -->
## Chaos Substrate

Use Chaos Substrate before non-trivial architecture, security, feature, or refactor work.

- Prefer \`chaos-agent update "\$PWD"\` after code changes or before deep investigation.
- Use \`chaos-agent context "\$PWD" "<task>"\` before implementation work.
- Use \`chaos-agent explain "\$PWD" "<feature>"\` to generate a focused static feature page.
- If MCP tools are available, use \`chaos_analyze\` to index and \`chaos_query\` for focused questions.
- Treat source code as higher priority than docs if they disagree.
- Read generated feature manifests in \`docs/features_memory/*.html\`; do not scan the whole docs tree.
- Feature-map story steps must use explicit \`node_ids\` and optional \`edge_ids\`, not graph expansion.

This section is intentionally portable. It assumes \`chaos-agent\` is on PATH.
<!-- chaos-substrate:end -->
EOF
  printf 'Wrote Chaos Substrate section to %s (%s)\n' "$file" "$title"
}

write_project_instructions() {
  repo="${1:-}"
  need_repo "$repo"
  if [ ! -d "$repo" ]; then
    printf 'Project directory does not exist: %s\n' "$repo" >&2
    exit 2
  fi
  repo="$(cd "$repo" && pwd)"
  append_managed_section "$repo/AGENTS.md" "generic agents"
  append_managed_section "$repo/CLAUDE.md" "Claude Code / Cowork"
}

ollama_setup() {
  if ! command -v ollama >/dev/null 2>&1; then
    cat <<'OLLAMA'
Ollama is not installed or is not on PATH.

Install Ollama:
  macOS / Windows: download from https://ollama.com/download
  Linux:           curl -fsSL https://ollama.com/install.sh | sh

After installing, start Ollama and rerun:
  scripts/chaos-agent ollama-setup
OLLAMA
    return 1
  fi

  if ! curl -fsS http://localhost:11434/api/tags >/dev/null 2>&1; then
    cat <<'OLLAMA'
Ollama CLI is installed, but the local server is not responding on http://localhost:11434.

Start Ollama:
  macOS / Windows: open the Ollama desktop app
  Linux:           ollama serve

Then rerun:
  scripts/chaos-agent ollama-setup
OLLAMA
    return 1
  fi

  ollama pull nomic-embed-text
  cat <<'OLLAMA'
Ollama embedding model is ready.

Use the local Ollama config:
  CHAOS_CONFIG=chaos-substrate.local.toml scripts/chaos-agent doctor
  CHAOS_CONFIG=chaos-substrate.local.toml scripts/chaos-agent init /absolute/path/to/project
OLLAMA
}

chaos() {
  "$BIN" --config "$CONFIG" "$@"
}

need_repo() {
  if [ "${1:-}" = "" ]; then
    usage
    exit 2
  fi
}

cmd="${1:-}"
shift || true

case "$cmd" in
  bootstrap)
    install_agent "${1:-${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}}"
    ensure_binary
    ensure_services
    chaos migrate
    chaos doctor
    ;;
  install-agent)
    install_agent "${1:-${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}}"
    ;;
  doctor)
    ensure_binary
    ensure_services
    chaos migrate
    chaos doctor
    ;;
  ollama-setup)
    ollama_setup
    ;;
  project-instructions)
    repo="${1:-}"
    write_project_instructions "$repo"
    ;;
  onboard)
    repo="${1:-}"
    need_repo "$repo"
    install_agent "${CHAOS_AGENT_BIN_DIR:-$HOME/.local/bin}"
    write_project_instructions "$repo"
    ensure_binary
    ensure_services
    chaos migrate
    chaos doctor
    chaos analyze "$repo"
    chaos refresh "$repo"
    ;;
  init)
    repo="${1:-}"
    need_repo "$repo"
    ensure_binary
    ensure_services
    chaos migrate
    chaos doctor
    chaos analyze "$repo"
    chaos refresh "$repo"
    ;;
  update)
    repo="${1:-}"
    need_repo "$repo"
    ensure_binary
    ensure_services
    chaos migrate
    chaos analyze "$repo"
    chaos refresh "$repo"
    ;;
  context)
    repo="${1:-}"
    task="${2:-}"
    need_repo "$repo"
    if [ "$task" = "" ]; then
      usage
      exit 2
    fi
    ensure_binary
    chaos feature-context "$repo" "$task"
    ;;
  explain)
    repo="${1:-}"
    task="${2:-}"
    need_repo "$repo"
    if [ "$task" = "" ]; then
      usage
      exit 2
    fi
    ensure_binary
    slug="$(slugify "$task")"
    if [ "$slug" = "" ]; then
      slug="feature-context"
    fi
    output="$repo/docs/features_memory/$slug-explanation.html"
    chaos feature-context "$repo" "$task" --output-html "$output"
    printf '\nWrote %s\n' "$output"
    ;;
  claude-code-add)
    scope="${1:-local}"
    project_dir="${2:-$PWD}"
    case "$scope" in
      local|project|user) ;;
      *)
        usage
        exit 2
        ;;
    esac
    if [ ! -d "$project_dir" ]; then
      printf 'Claude project directory does not exist: %s\n' "$project_dir" >&2
      exit 2
    fi
    if ! command -v claude >/dev/null 2>&1; then
      cat <<'CLAUDE'
Claude Code CLI is not installed or is not on PATH.

Install Claude Code first, then rerun:
  scripts/chaos-agent claude-code-add local
CLAUDE
      exit 1
    fi
    ensure_binary
    (
      cd "$project_dir"
      claude mcp add chaos-substrate \
        --scope "$scope" \
        --env "DATABASE_URL=${DATABASE_URL:-postgres://chaos:chaos@localhost:54329/chaos_substrate}" \
        -- "$BIN" --config "$CONFIG" mcp
    )
    ;;
  mcp)
    ensure_binary
    exec "$BIN" --config "$CONFIG" mcp
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage
    exit 2
    ;;
esac
